<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.unequipment.platform.modules.system.repository.SysUserRoleRepository">

  <select id="findByUserId" resultType="com.unequipment.platform.modules.system.entity.SysUserRole">
    select * from sys_user_role where user_id = #{userId}
  </select>

  <delete id="deleteByUserId">
    <!-- 用户角色覆盖绑定前先清理旧关系 -->
    delete from sys_user_role where user_id = #{userId}
  </delete>

  <delete id="deleteByRoleId">
    <!-- 角色禁用/删除时批量解绑关联用户 -->
    delete from sys_user_role where role_id = #{roleId}
  </delete>

  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    insert into sys_user_role(user_id, role_id, create_time)
    values(#{userId}, #{roleId}, #{createTime})
  </insert>

  <select id="countByRoleId" resultType="long">
    <!-- 角色删除前占用校验 -->
    select count(1) from sys_user_role where role_id = #{roleId}
  </select>

</mapper>
